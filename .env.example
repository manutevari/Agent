LLM_PROVIDER=local

# Grok uses the OpenAI-compatible chat completions API.
GROK_API_KEY=your_grok_api_key_here
GROK_BASE_URL=https://api.x.ai/v1
GROK_MODEL=grok-2-latest

# Gemini path. GOOGLE_API_KEY is enough for google-generativeai.
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# OpenAI / ChatGPT-compatible fallback.
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Hugging Face Inference Providers via OpenAI-compatible router.
HF_TOKEN=your_hugging_face_token_here
HF_BASE_URL=https://router.huggingface.co/v1
HF_MODEL=meta-llama/Llama-3.1-8B-Instruct

# Optional observability.
LANGSMITH_API_KEY=your_langsmith_key_if_any
LANGCHAIN_TRACING_V2=false
LANGSMITH_PROJECT=scientific-rag-chatbot
LANGSMITH_EVAL_DATASET=scientific-rag-eval
LANGSMITH_FEEDBACK_DATASET=scientific-rag-feedback

# Runtime controls.
ARTIFACT_DIR=artifacts
CACHE_FILE=artifacts/agent_cache.pkl
DATA_ZIP=
DATA_PATH=
MAX_DOCS=16
MAX_PAGES=8

# Optional monitoring and feedback loop.
WANDB_API_KEY=your_wandb_api_key_here
WANDB_PROJECT=scientific-rag-chatbot
WANDB_ENTITY=
WANDB_MODE=online
MONITOR_DIR=artifacts/monitoring
